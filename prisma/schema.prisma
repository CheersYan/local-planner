generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Setting {
  id        String   @id @default(cuid())
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key])
  @@map("settings")
}

model Task {
  id              String         @id @default(cuid())
  title           String
  status          String         @default("active")
  estimateMinutes Int
  remainingMinutes Int?
  actualMinutes   Int?
  dueDate         DateTime?
  plannedDate     DateTime?
  priority        Int            @default(0)
  locked          Boolean        @default(false)
  note            String?
  parentTaskId    String?
  deletedAt       DateTime?
  planSlots       PlanSlot[]
  completions     CompletionLog[]
  parentTask      Task?          @relation("TaskChildren", fields: [parentTaskId], references: [id])
  children        Task[]         @relation("TaskChildren")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([plannedDate])
  @@index([dueDate])
  @@index([parentTaskId])
  @@index([deletedAt])
  @@map("task")
}

model PlanSlot {
  id             String    @id @default(cuid())
  taskId         String
  slotDate       DateTime
  plannedMinutes Int
  position       Int       @default(0)
  locked         Boolean   @default(false)
  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([slotDate, position])
  @@index([taskId])
  @@index([slotDate])
  @@map("plan_slot")
}

model CompletionLog {
  id           String   @id @default(cuid())
  taskId       String
  loggedAt     DateTime
  minutesSpent Int?
  note         String?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([taskId])
  @@index([loggedAt])
  @@map("completion_log")
}

model BlackoutWindow {
  id        String   @id @default(cuid())
  start     DateTime
  end       DateTime
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([start, end])
  @@map("blackout_window")
}

model ChatAudit {
  id          String           @id @default(cuid())
  role        String
  messageId   String?
  message     String
  commandType String?
  payload     String?
  status      String           @default("pending")
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([messageId])
  @@index([createdAt])
  @@index([status])
  @@map("chat_audit")
}
